# Phase 0 only: Using tsx directly inside Node.js container for rapid iteration.
# Production configurations will compile TypeScript to static JS in later phases.
FROM node:22-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ENV PORT=4000
ENV DATABASE_PATH=/data/radar.sqlite

EXPOSE 4000

CMD ["npm", "run", "api:dev"]
