PORT=4000
DATABASE_PATH=/data/radar.sqlite

# Content Extraction (Phase 6)
JINA_READER_ENABLED=true
JINA_READER_BASE_URL=https://r.jina.ai
JINA_READER_TIMEOUT_MS=15000
EXTRACTION_MAX_CHARS=40000
EXTRACTION_BATCH_SIZE=25

# LLM Provider (Phase 7)
LLM_PROVIDER=mock
LLM_MODEL=mock-card-model

# Zhipu / GLM
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4.5-flash

# Groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-120b

# LLM Eval Compare
LLM_EVAL_COMPARE=false
LLM_EVAL_COMPARE_TARGETS=zhipu:glm-4.5-flash,groq:openai/gpt-oss-120b

# LLM Eval
LLM_EVAL_MAX_CHARS=30000
LLM_EVAL_OUTPUT_DIR=reports
LLM_EVAL_USE_LIVE_DB=false

# Enrichment (Phase 8)
ENRICH_BATCH_SIZE=10
ENRICH_MAX_CHARS=30000
ENRICH_RETRY_FAILED=false
ENRICH_CONCURRENCY=1
